FROM fedora:44

ARG HOST_UID=1000
ARG HOST_GID=1000

RUN dnf install -y \
    curl ca-certificates jq \
    vim sudo \
    git \
    && dnf clean all

RUN groupadd -g ${HOST_GID} opencode && \
    useradd -u ${HOST_UID} -g opencode -m -d /home/opencode -s /bin/bash opencode

RUN echo "opencode ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/opencode && \
    chmod 0440 /etc/sudoers.d/opencode

RUN mkdir -p /workspace && chown opencode:opencode /workspace

RUN ARCH=$(uname -m) && \
    if [ "$ARCH" = "x86_64" ]; then ARCH="x64"; fi && \
    if [ "$ARCH" = "aarch64" ]; then ARCH="arm64"; fi && \
    TMP=$(mktemp -d) && \
    curl -fsSL "https://github.com/anomalyco/opencode/releases/latest/download/opencode-linux-${ARCH}.tar.gz" \
        -o "${TMP}/opencode.tar.gz" && \
    tar -xzf "${TMP}/opencode.tar.gz" -C "${TMP}" && \
    mv "${TMP}/opencode" /usr/local/bin/opencode && \
    chmod +x /usr/local/bin/opencode && \
    rm -rf "${TMP}"

RUN mkdir -p /mnt/gcloud-adc

COPY scripts/opencode-entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

USER opencode
WORKDIR /workspace

ENTRYPOINT ["/entrypoint.sh"]
CMD ["opencode"]
